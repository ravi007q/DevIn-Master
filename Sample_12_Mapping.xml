<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powermart.dtd">
<POWERMART CREATION_DATE="06/29/2026 12:30:00" REPOSITORY_VERSION="184.93" PRODUCT_VERSION="10.5.0">
<REPOSITORY NAME="Rep_Snowflake_Migration" VERSION="184" CODEPAGE="UTF-8" DATABASETYPE="Oracle">
<FOLDER NAME="MIGRATION_PROJECT" BUSINESSNAME="Informatica to Snowflake Migration" SHARED="NOTSHARED">
    <MAPPING NAME="m_cascading_fallback_lookup" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="LKP_Active_Cache" TYPE="Lookup" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="IN_SRC_KEY" DATATYPE="varchar" PORTTYPE="INPUT" PRECISION="50"/>
            <TRANSFORMFIELD NAME="CACHE_SRC_KEY" DATATYPE="varchar" PORTTYPE="LOOKUP" PRECISION="50"/>
            <TRANSFORMFIELD NAME="ACTIVE_ID" DATATYPE="integer" PORTTYPE="LOOKUP/OUTPUT" PRECISION="10"/>
            <TABLEATTRIBUTE NAME="Lookup Condition" VALUE="CACHE_SRC_KEY = IN_SRC_KEY"/>
            <TABLEATTRIBUTE NAME="Lookup source table" VALUE="DIM_CUSTOMER_ACTIVE"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="LKP_Archive_Cache" TYPE="Lookup" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="IN_SRC_KEY" DATATYPE="varchar" PORTTYPE="INPUT" PRECISION="50"/>
            <TRANSFORMFIELD NAME="ARCH_SRC_KEY" DATATYPE="varchar" PORTTYPE="LOOKUP" PRECISION="50"/>
            <TRANSFORMFIELD NAME="ARCHIVE_ID" DATATYPE="integer" PORTTYPE="LOOKUP/OUTPUT" PRECISION="10"/>
            <TABLEATTRIBUTE NAME="Lookup Condition" VALUE="ARCH_SRC_KEY = IN_SRC_KEY"/>
            <TABLEATTRIBUTE NAME="Lookup source table" VALUE="DIM_CUSTOMER_ARCHIVE"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="EXP_Evaluate_Fallback" TYPE="Expression" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="ACTIVE_ID" DATATYPE="integer" PORTTYPE="INPUT"/>
            <TRANSFORMFIELD NAME="ARCHIVE_ID" DATATYPE="integer" PORTTYPE="INPUT"/>
            <!-- Staggered fallback evaluation logic -->
            <TRANSFORMFIELD NAME="O_FINAL_ID" DATATYPE="integer" PORTTYPE="OUTPUT" EXPRESSION="IIF(NOT ISNULL(ACTIVE_ID), ACTIVE_ID, IIF(NOT ISNULL(ARCHIVE_ID), ARCHIVE_ID, -1))"/>
        </TRANSFORMATION>
    </MAPPING>
</FOLDER>
</REPOSITORY>
</POWERMART>