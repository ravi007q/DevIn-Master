<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powermart.dtd">
<POWERMART CREATION_DATE="06/19/2026 12:55:00" REPOSITORY_VERSION="184.93" PRODUCT_VERSION="10.5.0">
<REPOSITORY NAME="Rep_Snowflake_Migration" VERSION="184" CODEPAGE="UTF-8" DATABASETYPE="Oracle">
<FOLDER NAME="MIGRATION_PROJECT" BUSINESSNAME="Informatica to Snowflake Migration" SHARED="NOTSHARED">
    <MAPPING NAME="m_customer_scd2_enterprise" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="SQ_STG_CUSTOMERS" TYPE="Source Qualifier" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="CUSTOMER_ID" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="CUSTOMER_NAME" DATATYPE="varchar" PORTTYPE="INPUT/OUTPUT" PRECISION="100" SCALE="0"/>
            <TRANSFORMFIELD NAME="ADDRESS" DATATYPE="varchar" PORTTYPE="INPUT/OUTPUT" PRECISION="250" SCALE="0"/>
            <TRANSFORMFIELD NAME="PHONE" DATATYPE="varchar" PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0"/>
            <TRANSFORMFIELD NAME="TIER" DATATYPE="varchar" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT stg.CUSTOMER_ID, stg.CUSTOMER_NAME, stg.ADDRESS, stg.PHONE, stg.TIER FROM STG_CUSTOMERS stg INNER JOIN STG_REGIONS r ON stg.REGION_ID = r.REGION_ID WHERE stg.EMAIL IS NOT NULL"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="LKP_Dim_Customer" TYPE="Lookup" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="IN_CUSTOMER_ID" DATATYPE="integer" PORTTYPE="INPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="CUSTOMER_ID" DATATYPE="integer" PORTTYPE="LOOKUP" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="CUSTOMER_SK" DATATYPE="integer" PORTTYPE="LOOKUP/OUTPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="ROW_HASH_MD5" DATATYPE="varchar" PORTTYPE="LOOKUP/OUTPUT" PRECISION="32" SCALE="0"/>
            <TABLEATTRIBUTE NAME="Lookup Condition" VALUE="CUSTOMER_ID = IN_CUSTOMER_ID"/>
            <TABLEATTRIBUTE NAME="Source Filter" VALUE="IS_ACTIVE = 'Y'"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="EXP_SCD_Logic" TYPE="Expression" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="CUSTOMER_ID" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="ADDRESS" DATATYPE="varchar" PORTTYPE="INPUT" PRECISION="250" SCALE="0"/>
            <TRANSFORMFIELD NAME="PHONE" DATATYPE="varchar" PORTTYPE="INPUT" PRECISION="20" SCALE="0"/>
            <TRANSFORMFIELD NAME="TIER" DATATYPE="varchar" PORTTYPE="INPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="LKP_CUSTOMER_SK" DATATYPE="integer" PORTTYPE="INPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="LKP_ROW_HASH_MD5" DATATYPE="varchar" PORTTYPE="INPUT" PRECISION="32" SCALE="0"/>
            <TRANSFORMFIELD NAME="V_CURRENT_HASH" DATATYPE="varchar" PORTTYPE="LOCALVARIABLE" PRECISION="32" EXPRESSION="MD5(ISNULL(ADDRESS,'') || '||' || ISNULL(PHONE,'') || '||' || ISNULL(TIER,''))"/>
            <TRANSFORMFIELD NAME="O_ROW_HASH" DATATYPE="varchar" PORTTYPE="OUTPUT" PRECISION="32" EXPRESSION="V_CURRENT_HASH"/>
            <TRANSFORMFIELD NAME="O_IS_NEW_RECORD" DATATYPE="integer" PORTTYPE="OUTPUT" PRECISION="1" EXPRESSION="IIF(ISNULL(LKP_CUSTOMER_SK), 1, 0)"/>
            <TRANSFORMFIELD NAME="O_IS_CHANGED_RECORD" DATATYPE="integer" PORTTYPE="OUTPUT" PRECISION="1" EXPRESSION="IIF(NOT ISNULL(LKP_CUSTOMER_SK) AND V_CURRENT_HASH != LKP_ROW_HASH_MD5, 1, 0)"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="RTR_SCD_Rows" TYPE="Router" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="CUSTOMER_ID" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="O_IS_NEW_RECORD" DATATYPE="integer" PORTTYPE="INPUT" PRECISION="1"/>
            <TRANSFORMFIELD NAME="O_IS_CHANGED_RECORD" DATATYPE="integer" PORTTYPE="INPUT" PRECISION="1"/>
            <GROUP NAME="INSERT_NEW" EXPRESSION="O_IS_NEW_RECORD = 1"/>
            <GROUP NAME="INSERT_UPDATE" EXPRESSION="O_IS_CHANGED_RECORD = 1"/>
            <GROUP NAME="UPDATE_OLD" EXPRESSION="O_IS_CHANGED_RECORD = 1"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="UPD_Old_Version" TYPE="Update Strategy" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="CUSTOMER_ID" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TABLEATTRIBUTE NAME="Update Strategy Expression" VALUE="DD_UPDATE"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="SEQ_Cust_Key" TYPE="Sequence" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="NEXTVAL" DATATYPE="bigint" PORTTYPE="OUTPUT" PRECISION="19" SCALE="0"/>
            <TABLEATTRIBUTE NAME="Start Value" VALUE="1"/>
            <TABLEATTRIBUTE NAME="Increment By" VALUE="1"/>
        </TRANSFORMATION>
    </MAPPING>
</FOLDER>
</REPOSITORY>
</POWERMART>