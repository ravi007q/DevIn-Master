<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powermart.dtd">
<POWERMART CREATION_DATE="06/23/2026 12:00:00" REPOSITORY_VERSION="184.93" PRODUCT_VERSION="10.5.0">
<REPOSITORY NAME="Rep_Snowflake_Migration" VERSION="184" CODEPAGE="UTF-8" DATABASETYPE="Oracle">
<FOLDER NAME="MIGRATION_PROJECT" BUSINESSNAME="Informatica to Snowflake Migration" SHARED="NOTSHARED">
    <MAPPING NAME="m_txn_state_tracking_complex" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="SQ_STG_TXNS" TYPE="Source Qualifier" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="ACCOUNT_ID" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="TXN_DATE" DATATYPE="date/time" PORTTYPE="INPUT/OUTPUT"/>
            <TRANSFORMFIELD NAME="STATUS" DATATYPE="varchar" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="AMOUNT" DATATYPE="decimal" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
            <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT ACCOUNT_ID, TXN_DATE, STATUS, AMOUNT FROM STG_TXNS ORDER BY ACCOUNT_ID, TXN_DATE ASC"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="EXP_State_Engine" TYPE="Expression" VERSIONNUMBER="1">
            <!-- Inputs -->
            <TRANSFORMFIELD NAME="ACCOUNT_ID" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="TXN_DATE" DATATYPE="date/time" PORTTYPE="INPUT/OUTPUT"/>
            <TRANSFORMFIELD NAME="STATUS" DATATYPE="varchar" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="AMOUNT" DATATYPE="decimal" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
            <!-- Stateful Variables (Order of evaluation matters in Informatica) -->
            <TRANSFORMFIELD NAME="V_IS_NEW_ACCOUNT" DATATYPE="integer" PORTTYPE="LOCALVARIABLE" PRECISION="1" EXPRESSION="IIF(ACCOUNT_ID != V_PREV_ACCOUNT_ID, 1, 0)"/>
            <TRANSFORMFIELD NAME="V_STATE_CHANGED" DATATYPE="integer" PORTTYPE="LOCALVARIABLE" PRECISION="1" EXPRESSION="IIF(V_IS_NEW_ACCOUNT = 1 OR STATUS != V_PREV_STATUS, 1, 0)"/>
            <!-- Output Ports -->
            <TRANSFORMFIELD NAME="O_STATE_CHANGED_FLAG" DATATYPE="integer" PORTTYPE="OUTPUT" PRECISION="1" EXPRESSION="V_STATE_CHANGED"/>
            <!-- State trailing assignments (Evaluated last) -->
            <TRANSFORMFIELD NAME="V_PREV_ACCOUNT_ID" DATATYPE="integer" PORTTYPE="LOCALVARIABLE" PRECISION="10" SCALE="0" EXPRESSION="ACCOUNT_ID"/>
            <TRANSFORMFIELD NAME="V_PREV_STATUS" DATATYPE="varchar" PORTTYPE="LOCALVARIABLE" PRECISION="10" SCALE="0" EXPRESSION="STATUS"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="RTR_State_Changes" TYPE="Router" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="ACCOUNT_ID" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="TXN_DATE" DATATYPE="date/time" PORTTYPE="INPUT/OUTPUT"/>
            <TRANSFORMFIELD NAME="STATUS" DATATYPE="varchar" PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0"/>
            <TRANSFORMFIELD NAME="AMOUNT" DATATYPE="decimal" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
            <TRANSFORMFIELD NAME="O_STATE_CHANGED_FLAG" DATATYPE="integer" PORTTYPE="INPUT" PRECISION="1"/>
            <GROUP NAME="STATE_MODIFIED" EXPRESSION="O_STATE_CHANGED_FLAG = 1"/>
        </TRANSFORMATION>
    </MAPPING>
</FOLDER>
</REPOSITORY>
</POWERMART>