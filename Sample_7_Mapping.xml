<REPOSITORY NAME="Rep_Snowflake_Migration" VERSION="184" CODEPAGE="UTF-8" DATABASETYPE="Oracle">
<FOLDER NAME="MIGRATION_PROJECT" BUSINESSNAME="Informatica to Snowflake Migration" SHARED="NOTSHARED">
    <MAPPING NAME="m_transaction_denormalization" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="AGG_Pivot_Lines" TYPE="Aggregator" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="INVOICE_ID" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT/GROUPBY" PRECISION="12" SCALE="0"/>
            <TRANSFORMFIELD NAME="LINE_TYPE" DATATYPE="varchar" PORTTYPE="INPUT" PRECISION="20"/>
            <TRANSFORMFIELD NAME="LINE_AMOUNT" DATATYPE="decimal" PORTTYPE="INPUT" PRECISION="15" SCALE="2"/>
            <!-- Complex conditional metrics evaluating categorical subsets -->
            <TRANSFORMFIELD NAME="TOTAL_TAX_AMT" DATATYPE="decimal" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2" EXPRESSION="SUM(IIF(LINE_TYPE = 'TAX', LINE_AMOUNT, 0))"/>
            <TRANSFORMFIELD NAME="TOTAL_ITEM_AMT" DATATYPE="decimal" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2" EXPRESSION="SUM(IIF(LINE_TYPE = 'ITEM', LINE_AMOUNT, 0))"/>
            <TRANSFORMFIELD NAME="TOTAL_FREIGHT_AMT" DATATYPE="decimal" PORTTYPE="OUTPUT" PRECISION="15" SCALE="2" EXPRESSION="SUM(IIF(LINE_TYPE = 'FREIGHT', LINE_AMOUNT, 0))"/>
        </TRANSFORMATION>
    </MAPPING>
</FOLDER>
