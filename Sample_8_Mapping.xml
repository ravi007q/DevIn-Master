<!DOCTYPE POWERMART SYSTEM "powermart.dtd">
<POWERMART CREATION_DATE="06/29/2026 12:00:00" REPOSITORY_VERSION="184.93" PRODUCT_VERSION="10.5.0">
<REPOSITORY NAME="Rep_Snowflake_Migration" VERSION="184" CODEPAGE="UTF-8" DATABASETYPE="Oracle">
<FOLDER NAME="MIGRATION_PROJECT" BUSINESSNAME="Informatica to Snowflake Migration" SHARED="NOTSHARED">
    <MAPPING NAME="m_conditional_lookup_bypass" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="RTR_Bypass_Check" TYPE="Router" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="TXN_ID" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT" PRECISION="12" SCALE="0"/>
            <TRANSFORMFIELD NAME="LINE_STATUS" DATATYPE="varchar" PORTTYPE="INPUT/OUTPUT" PRECISION="10"/>
            <TRANSFORMFIELD NAME="AMOUNT" DATATYPE="decimal" PORTTYPE="INPUT/OUTPUT" PRECISION="15" SCALE="2"/>
            <!-- Route to Lookup only if the transaction status requires historical verification -->
            <GROUP NAME="NEED_HIST_LOOKUP" EXPRESSION="LINE_STATUS = 'REVERSED' OR LINE_STATUS = 'ADJUSTED'"/>
            <GROUP NAME="STRAIGHT_THROUGH" EXPRESSION="DEFAULT"/>
        </TRANSFORMATION>
        <TRANSFORMATION NAME="LKP_Transaction_History" TYPE="Lookup" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="IN_TXN_ID" DATATYPE="integer" PORTTYPE="INPUT" PRECISION="12" SCALE="0"/>
            <TRANSFORMFIELD NAME="HIST_TXN_ID" DATATYPE="integer" PORTTYPE="LOOKUP" PRECISION="12" SCALE="0"/>
            <TRANSFORMFIELD NAME="ORIGINAL_VAL" DATATYPE="decimal" PORTTYPE="LOOKUP/OUTPUT" PRECISION="15" SCALE="2"/>
            <TABLEATTRIBUTE NAME="Lookup Condition" VALUE="HIST_TXN_ID = IN_TXN_ID"/>
            <TABLEATTRIBUTE NAME="Lookup source table" VALUE="FACT_TRANSACTION_HISTORY"/>
        </TRANSFORMATION>
    </MAPPING>
</FOLDER>
</REPOSITORY>
</POWERMART>