<!DOCTYPE POWERMART SYSTEM "powermart.dtd">
<POWERMART CREATION_DATE="06/29/2026 12:00:00" REPOSITORY_VERSION="184.93" PRODUCT_VERSION="10.5.0">
<REPOSITORY NAME="Rep_Snowflake_Migration" VERSION="184" CODEPAGE="UTF-8" DATABASETYPE="Oracle">
<FOLDER NAME="MIGRATION_PROJECT" BUSINESSNAME="Informatica to Snowflake Migration" SHARED="NOTSHARED">
    <MAPPING NAME="m_multi_target_clearinghouse" ISVALID="YES" VERSIONNUMBER="1">
        <TRANSFORMATION NAME="RTR_Data_Clearinghouse" TYPE="Router" VERSIONNUMBER="1">
            <TRANSFORMFIELD NAME="RECORD_ID" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT" PRECISION="12" SCALE="0"/>
            <TRANSFORMFIELD NAME="COUNTRY_CODE" DATATYPE="varchar" PORTTYPE="INPUT/OUTPUT" PRECISION="3"/>
            <TRANSFORMFIELD NAME="RISK_SCORE" DATATYPE="integer" PORTTYPE="INPUT/OUTPUT" PRECISION="3"/>
            <!-- Complex routing filters pointing to three different physical files/tables -->
            <GROUP NAME="GRP_DOMESTIC_HIGH_RISK" EXPRESSION="COUNTRY_CODE = 'USA' AND RISK_SCORE &gt; 80"/>
            <GROUP NAME="GRP_INTERNATIONAL" EXPRESSION="COUNTRY_CODE != 'USA'"/>
            <GROUP NAME="GRP_AUDIT_LOG" EXPRESSION="RISK_SCORE &gt; 50"/>
        </TRANSFORMATION>
    </MAPPING>
</FOLDER>
</REPOSITORY>
</POWERMART>